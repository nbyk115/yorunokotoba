TRIP_WIRE_DAYS = 30


def check_trip_wire() -> bool:
    """30 日超過 = brand-guardian 自動 REJECT、即実行禁止"""
    if not LAST_RUN_FILE.exists():
        return True
    last = datetime.fromisoformat(LAST_RUN_FILE.read_text().strip())
    delta = datetime.now() - last
    if delta > timedelta(days=TRIP_WIRE_DAYS):
        print(f"REJECT: 前回 dream pass から {delta.days} 日経過 (>30 日)")
        print("brand-guardian 規律違反、規律改訂後に再実行")
        return False
    return True


def gather_sessions(limit: int = 100) -> list[str]:
    """Phase 1: jsonl 直接送信禁止、文書構造のみ抽出 (brand-guardian 要件 2 選択肢 B)"""
    sessions = sorted(
        glob.glob(str(SESSION_DIR / "*" / "sessions" / "*.jsonl")),
        key=os.path.getmtime,
        reverse=True,
    )[:limit]

    transcripts = []
    for s in sessions:
        with open(s) as f:
            msgs = [json.loads(line) for line in f if line.strip()]
        clean = [m for m in msgs if m.get("type") in ("user", "assistant")]
        # 機密マスク: 関根さん / 水野さん / N&Y Craft / 財務数値
        masked = mask_sensitive(clean)
        transcripts.append("\n".join(json.dumps(m, ensure_ascii=False) for m in masked))
    return transcripts


def mask_sensitive(msgs: list[dict]) -> list[dict]:
    """brand-guardian 要件 2: 固有名詞 / 財務数値マスク"""
    import re
    patterns = [
        (r"関根さん", "[CLIENT_A]"),
        (r"水野さん", "[CLIENT_B]"),
        (r"N&Y Craft", "[CLIENT_A_COMPANY]"),
        (r"\d+,?\d*\s*万円", "[REDACTED_JPY]"),
        (r"\$\d+,?\d*[KMB]?", "[REDACTED_USD]"),
    ]
    masked = []
    for m in msgs:
        s = json.dumps(m, ensure_ascii=False)
        for pat, repl in patterns:
            s = re.sub(pat, repl, s)
        masked.append(json.loads(s))
    return masked


