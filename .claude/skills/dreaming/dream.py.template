def write_diff_only(new_content: str) -> None:
    """brand-guardian 要件 1: 自動 apply 禁止、diff 提示のみ"""
    OUTPUT.parent.mkdir(parents=True, exist_ok=True)
    OUTPUT.write_text(new_content)
    print(f"\n=== Dream output: {OUTPUT} ===")
    if EXISTING.exists():
        subprocess.run(
            ["git", "diff", "--no-color", "--no-index", str(EXISTING), str(OUTPUT)]
        )
    print("\nIMPORTANT: 自動 apply 禁止。user 承認 + Phased Preamble 4 段階後に Edit 実行")


def main():
    if not check_trip_wire():
        return
    existing = EXISTING.read_text() if EXISTING.exists() else ""
    transcripts = gather_sessions(limit=100)
    print(f"Collected {len(transcripts)} sessions")
    new = dream(transcripts, existing)
    write_diff_only(new)
    LAST_RUN_FILE.write_text(datetime.now().isoformat())


if __name__ == "__main__":
    main()
