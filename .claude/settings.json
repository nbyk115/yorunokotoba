{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extendedThinking": true,
  "effortLevel": "high",
  "cleanupPeriodDays": 365,
  "env": {
    "MAX_THINKING_TOKENS": "31999",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prompt-rules.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '【品質ゲート確認】反証モード3段階を実行しましたか？ 評価カードを記録しましたか？ brand-guidelinesに準拠していますか？'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.command // empty' 2>/dev/null); case \"$CMD\" in *'curl -X POST'*|*'git push'*|*'npx vercel deploy'*) echo \"⚠️ 外部送信検知: $CMD\" ;; esac; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.file_path // .filePath // empty' 2>/dev/null); if [ -n \"$file\" ]; then case \"$file\" in *.ts|*.tsx|*.js|*.jsx) npx prettier --write \"$file\" 2>/dev/null;; esac; fi"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(*> .env*)",
      "Bash(cat *.env*)",
      "Bash(cat *SECRET*)",
      "Bash(cat *credentials*)",
      "Bash(cat *secret*)",
      "Bash(cat /etc/passwd*)",
      "Bash(cat /etc/shadow*)",
      "Bash(chmod 777 *)",
      "Bash(env *)",
      "Bash(git push * --force*)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(printenv *)",
      "Bash(rm -rf ./*)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Read(*credentials*)",
      "Read(*secret*)",
      "Read(.env*)"
    ]
  }
}
