{
  "$schema": "./tokens.schema.json",
  "version": "1.0.0",
  "project": "よるのことば",
  "description": "デザイントークンのSingle Source of Truth (SSOT)",
  "colors": {
    "light": {
      "bg1": {
        "value": "#FFF5F0",
        "usage": "Background primary",
        "why": "夜明け前の淡い空色。占いの神秘性と温かみを両立"
      },
      "rose": {
        "value": "#E8627C",
        "usage": "Primary accent, CTA",
        "why": "コーラルピンク。情緒的な占いの世界観にマッチ"
      },
      "pink": {
        "value": "#D4506A",
        "usage": "Primary darker variant",
        "why": "CTAのホバー状態用"
      },
      "blush": {
        "value": "#F2A0B0",
        "usage": "Secondary accent",
        "why": "柔らかい補助色"
      },
      "lavender": {
        "value": "#B08ACF",
        "usage": "Tertiary accent",
        "why": "神秘的な紫。プレミアム機能・特別な要素に"
      },
      "gold": {
        "value": "#D4A853",
        "usage": "Premium, highlight",
        "why": "プレミアムバッジ・特別なハイライト"
      },
      "t1": {
        "value": "#3A2830",
        "usage": "Text primary",
        "why": "純粋な黒を避け、温かみのある濃茶"
      },
      "t2": {
        "value": "rgba(58,40,48,0.72)",
        "usage": "Text secondary",
        "why": "主要テキストの72%濃度"
      },
      "t3": {
        "value": "rgba(58,40,48,0.56)",
        "usage": "Text tertiary",
        "why": "補助テキスト"
      },
      "card": {
        "value": "var(--card-secondary)",
        "usage": "Card background (migration alias - use cardPrimary or cardSecondary directly)",
        "why": "後方互換性のための移行エイリアス。新規コンポーネントは cardPrimary/cardSecondary を直接参照"
      },
      "cardPrimary": {
        "value": "rgba(255,255,255,0.96)",
        "usage": "Primary card background - 画面主役カード（1画面に1枚）",
        "why": "不透明度高め。主役コンテンツ（占い結果・アウラ）を背景から浮かせる"
      },
      "cardSecondary": {
        "value": "rgba(255,255,255,0.62)",
        "usage": "Secondary card background - サブカード・一覧カード",
        "why": "不透明度低め。背景グラデーションを透過させ奥行きを演出"
      },
      "borderPrimary": {
        "value": "rgba(58,40,48,0.10)",
        "usage": "Primary card border",
        "why": "主役カード境界線。見えるが主張しない微妙な区切り"
      },
      "borderSecondary": {
        "value": "rgba(58,40,48,0.05)",
        "usage": "Secondary card border",
        "why": "サブカード境界線。さらに薄くしてカード群の連続感を保つ"
      }
    },
    "dark": {
      "bg1": {
        "value": "#0D0B0E",
        "usage": "Background primary",
        "why": "純粋な黒を避け、ほのかに紫がかった夜色"
      },
      "rose": {
        "value": "#F0809A",
        "usage": "Primary accent",
        "why": "ダークモード用に明度を上げたローズ"
      },
      "t1": {
        "value": "#F0E8EC",
        "usage": "Text primary",
        "why": "純粋な白を避け、温かみのある生成り"
      },
      "t2": {
        "value": "rgba(240,232,236,0.86)",
        "usage": "Text secondary",
        "why": "夜色背景で本文・補助テキストが読めるコントラストを確保"
      },
      "t3": {
        "value": "rgba(240,232,236,0.70)",
        "usage": "Text tertiary",
        "why": "注釈・メタ情報。暗背景でも視認できる下限の濃さ"
      },
      "card": {
        "value": "var(--card-secondary)",
        "usage": "Card background (migration alias)",
        "why": "後方互換性のための移行エイリアス"
      },
      "cardPrimary": {
        "value": "rgba(34,27,37,0.92)",
        "usage": "Primary card background - dark mode",
        "why": "ダークモード主役カード。深い紫がかった暗色で夜の神秘感を演出"
      },
      "cardSecondary": {
        "value": "rgba(28,22,30,0.55)",
        "usage": "Secondary card background - dark mode",
        "why": "ダークモードサブカード。半透明で夜色背景を透過"
      },
      "borderPrimary": {
        "value": "rgba(240,232,236,0.12)",
        "usage": "Primary card border - dark mode",
        "why": "ダークモード主役カード境界。白系で暗背景に見える"
      },
      "borderSecondary": {
        "value": "rgba(240,232,236,0.06)",
        "usage": "Secondary card border - dark mode",
        "why": "ダークモードサブカード境界。さらに薄く"
      }
    }
  },
  "typography": {
    "heading": {
      "family": "Zen Maru Gothic",
      "fallback": "Hiragino Maru Gothic Pro, BIZ UDGothic, sans-serif",
      "weights": [400, 500, 700],
      "why": "丸ゴシックで警戒心を解き、占いの「話を聞いてもらえる」安心感を作る"
    },
    "accent": {
      "family": "Cormorant",
      "weights": [300, 400, 500],
      "italic": true,
      "why": "装飾的なセリフ体。引用や詩的な表現に使用"
    }
  },
  "spacing": {
    "base": 4,
    "scale": [4, 8, 12, 16, 20, 24, 32, 48],
    "why": "4px基準。8の倍数ではなく4の倍数にすることで細かい調整が可能"
  },
  "radius": {
    "card": 18,
    "button": 14,
    "input": 12,
    "tag": 20,
    "avatar": "50%",
    "modal": 24,
    "why": "シャープな角を使わない。柔らかさ・包容感を表現するため最小8px"
  },
  "animation": {
    "fadeIn": "500ms ease",
    "slideUp": "450ms ease",
    "staggerDelay": "50ms",
    "hoverTransform": "200ms ease",
    "themeToggle": "300ms ease",
    "why": "長すぎず短すぎず。ユーザーが「反応」を感じられる速度"
  },
  "breakpoints": {
    "mobile": 0,
    "tablet": 601,
    "desktop": 901,
    "maxWidth": 480,
    "why": "デスクトップはmax-width:480pxで中央寄せ。アプリ風の見た目を維持"
  }
}
